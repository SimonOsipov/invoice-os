{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["@playwright/test", "node"]
  },
  "include": ["smoke", "topology", "api", "rule-set.ts", "targets.ts", "targets.test.ts", "import-meta-env.d.ts", "playwright.config.ts", "playwright.topology.config.ts", "playwright.api.config.ts"]
}
