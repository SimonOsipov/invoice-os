{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "buildArgs": { "SERVICE": "portfolio" },
    "watchPatterns": [
      "cmd/portfolio/**",
      "internal/portfolio/**",
      "internal/platform/**",
      "internal/audit/**",
      "go.mod",
      "go.sum",
      "Dockerfile"
    ]
  },
  "deploy": {
    "healthcheckPath": "/healthz",
    "restartPolicyType": "ON_FAILURE"
  }
}
