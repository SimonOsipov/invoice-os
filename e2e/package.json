{
  "name": "@invoice-os/e2e",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Playwright smoke suite for the three deployed SPAs (M1-08): each app loads its main mock view with no console errors.",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test",
    "test:topology": "playwright test --config playwright.topology.config.ts",
    "test:api": "playwright test --config playwright.api.config.ts",
    "test:demo": "playwright test --config playwright.demo.config.ts",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@invoice-os/api-client": "workspace:*",
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8",
    "pg": "^8",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
