# Local dev-DB connection strings for the M2-02 loop. Copy to `.env` (gitignored)
# and adjust only if you change docker-compose.yml. These point at the local
# docker-compose Postgres on localhost:5432 (database: invoice_os).
#
# `make dev-db` does NOT need this file — it bootstraps the roles inside the
# container. These vars are what the lower-level `make migrate-*` / `db-bootstrap`
# targets read (the Makefile `-include`s .env). See docs/migrations.md §1 and §6.
#
# The three identities are deliberately distinct (docs/migrations.md §1). NEVER
# point DATABASE_URL or DATABASE_MIGRATION_URL at the superuser: a superuser has
# BYPASSRLS and every tenant-isolation policy silently becomes a no-op.

# App runtime identity — invoice_app (NOBYPASSRLS). Used by service binaries and `go test`.
DATABASE_URL=postgres://invoice_app:app@localhost:5432/invoice_os?sslmode=disable

# Migration identity — invoice_migrator (NOBYPASSRLS). Used by goose (make migrate-*).
DATABASE_MIGRATION_URL=postgres://invoice_migrator:migrator@localhost:5432/invoice_os?sslmode=disable

# Superuser — used ONLY by db/bootstrap.sql at provisioning. `make dev-db`
# bootstraps in-container and does not use this; it's here for running
# `make db-bootstrap` directly against the compose DB (needs a host psql client).
DATABASE_SUPERUSER_URL=postgres://postgres:postgres@localhost:5432/invoice_os?sslmode=disable

# Dev-default role passwords used by the `make dev-db` bootstrap step.
MIGRATOR_PASSWORD=migrator
APP_PASSWORD=app
# invoice_tenant_reader — the M2-06 cross-tenant enumeration role. No runtime URL is
# wired yet; its connection string is provisioned when M5-06 (reconciliation) needs it.
READER_PASSWORD=reader
