# .env.example — env for the migration / DB tooling (root Makefile, db/bootstrap.sql).
#
# Copy to .env (gitignored) for local `make migrate-*` / `make db-bootstrap`.
# Dev-safe placeholder values ONLY — real credentials live only in Railway.
# This is repo-level tooling env; each service binary keeps its own
# cmd/<svc>/.env.example (see docs/add-a-service.md §4).
#
# Three distinct connection identities (never collapse them — the superuser URL
# silently disables RLS; see docs/migrations.md):
#   DATABASE_URL           app role (invoice_app)      — runtime queries
#   DATABASE_MIGRATION_URL migrator role (invoice_migrator) — goose migrations
#   DATABASE_SUPERUSER_URL superuser (postgres)        — db-bootstrap ONLY, one-time

DATABASE_URL=postgres://invoice_app:app@localhost:5432/invoice_os?sslmode=disable
DATABASE_MIGRATION_URL=postgres://invoice_migrator:migrator@localhost:5432/invoice_os?sslmode=disable
DATABASE_SUPERUSER_URL=postgres://postgres:postgres@localhost:5432/invoice_os?sslmode=disable

# Role passwords db-bootstrap sets on invoice_migrator / invoice_app. Must match
# the passwords embedded in the URLs above.
MIGRATOR_PASSWORD=migrator
APP_PASSWORD=app
