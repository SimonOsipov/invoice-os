{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "frontend/ops-console/Dockerfile",
    "watchPatterns": [
      "frontend/ops-console/**",
      "packages/design-tokens/**",
      "pnpm-lock.yaml"
    ]
  },
  "deploy": {
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
